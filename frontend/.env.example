# Frontend environment variables.
# Copy to `.env.local` and fill in real values. All NEXT_PUBLIC_* are inlined at
# build time, so changes require a rebuild.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=vi

# Absolute site origin used to build links (e.g. product-inquiry message URL).
# Optional — falls back to the browser origin at runtime if unset.
NEXT_PUBLIC_SITE_URL=           # e.g. https://vinfurniture.vn

# Contact channels (deep-links). Leave a value empty to hide that channel.
NEXT_PUBLIC_ZALO_PHONE=          # digits only, e.g. 0901234567 -> https://zalo.me/<phone>
NEXT_PUBLIC_FB_PAGE=             # page username or id, e.g. vinfurniture -> https://m.me/<page>
NEXT_PUBLIC_HOTLINE=             # E.164, e.g. +84901234567 -> tel:<hotline>
