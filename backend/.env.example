# ── Core ─────────────────────────────────────────────────────────────────────
APP_NAME=Wood Furniture Ecommerce
ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wood_furniture

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

CUSTOMER_JWT_EXPIRE_MINUTES=15
CUSTOMER_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Admin seed account ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ── URLs ─────────────────────────────────────────────────────────────────────
SITE_BASE_URL=https://vinfurniture.vn
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── payOS ────────────────────────────────────────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:3000/vi/checkout/return
PAYOS_CANCEL_URL=http://localhost:3000/vi/checkout/cancel
# Public URL that payOS calls with webhook — use ngrok for local dev
PAYOS_WEBHOOK_URL=https://<tunnel>.ngrok.io/api/v1/webhooks/payos

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# ── Email ─────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER=console  →  prints to stdout (local dev, no Resend needed)
# EMAIL_PROVIDER=resend   →  sends real email via Resend
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=Wood Furniture <no-reply@example.com>
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# ── Redis / Arq worker ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
ARQ_QUEUE_NAME=vin_furniture_jobs

# Minutes after last activity before a cart is considered abandoned (min: 15)
ABANDONED_CART_DELAY_MINUTES=120
# Hours before a recovery token expires (min: 1)
ABANDONED_CART_TOKEN_TTL_HOURS=168
# How often the worker scans for abandoned carts, in minutes (min: 5)
ABANDONED_CART_SCAN_INTERVAL_MINUTES=15

# ── Promotion engine ──────────────────────────────────────────────────────────
PROMOTION_TIMEZONE=Asia/Ho_Chi_Minh
# Must equal 1 in Ver 0.5 — stacking not supported
PROMOTION_MAX_ACTIVE_PER_ORDER=1
# Maximum length of a coupon code
PROMOTION_MAX_COUPON_CODE_LENGTH=40
